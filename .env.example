# AWS temporary credentials from the AWS Academy / Vocareum lab
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_SESSION_TOKEN=your_session_token_here
AWS_DEFAULT_REGION=us-east-1

# S3 paths
S3_BUCKET=bigdata-salmonicultura-fabian
S3_RAW_PREFIX=raw/productive_data/
S3_RAW_KEY=raw/productive_data/productive_data.csv
S3_PROCESSED_PREFIX=processed/productive_kpi/
S3_EXPORTS_PREFIX=exports/productive_kpi_csv/

# Athena RAW layer
ATHENA_DATABASE=salmonicultura_raw_db
ATHENA_RAW_TABLE=productive_data_raw
ATHENA_OUTPUT=s3://bigdata-salmonicultura-fabian/exports/athena_results/
CSV_DELIMITER=;

# Athena analytical / data warehouse layer
ATHENA_DW_DATABASE=salmonicultura_dw_db
ATHENA_PROCESSED_TABLE=productive_kpi_processed

# Local Java / Hadoop configuration for PySpark on Windows
JAVA_HOME=C:\Program Files\Eclipse Adoptium\jdk-17.0.19.10-hotspot
HADOOP_HOME=C:\hadoop

# Optional ML / dashboard outputs
S3_ML_DATASET_PREFIX=ml/dataset/
S3_ML_TRAIN_PREFIX=ml/train/
S3_ML_TEST_PREFIX=ml/test/
S3_MODELS_PREFIX=models/
S3_ML_PREDICTIONS_PREFIX=exports/ml_predictions/

ATHENA_ML_DATASET_TABLE=productive_ml_dataset
ATHENA_ML_TRAIN_TABLE=productive_ml_train
ATHENA_ML_TEST_TABLE=productive_ml_test
ATHENA_ML_PREDICTIONS_TABLE=productive_ml_predictions